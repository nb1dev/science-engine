{
  "_doc": "Trigger rules for root cause domain evaluation in generate_health_report.py. Each domain maps to one or more questionnaire field checks. The engine evaluates these conditions against questionnaire data to determine which domains are active for a given sample.",
  "_version": "1.0",
  "_operators": {
    ">=": "Greater than or equal to (numeric)",
    "<=": "Less than or equal to (numeric)",
    ">": "Greater than (numeric)",
    "<": "Less than (numeric)",
    "==": "Exact match (string, bool, or numeric)",
    "!=": "Not equal (string, bool, or numeric)",
    "in": "Value is in the provided list",
    "not_in": "Value is NOT in the provided list",
    "exists": "Field exists and is not null/empty",
    "any_true": "At least one sub-field evaluates to true"
  },
  "_logic": "Multiple conditions within a domain use AND logic by default. Use 'logic: or' to switch to OR. 'confidence' (confirmed | likely | possible) is assigned based on trigger strength.",

  "antibiotic_use": {
    "trigger_conditions": [
      {
        "field_path": "questionnaire_data.step_7.antibiotics_past_year",
        "operator": "==",
        "value": true,
        "confidence_contribution": "confirmed"
      },
      {
        "field_path": "questionnaire_data.step_7.antibiotic_use_past_year",
        "operator": "==",
        "value": "yes",
        "confidence_contribution": "confirmed"
      },
      {
        "field_path": "questionnaire_data.step_7.long_term_antibiotics",
        "operator": "==",
        "value": true,
        "confidence_contribution": "confirmed"
      },
      {
        "field_path": "questionnaire_data.step_3.antibiotic_courses",
        "operator": "exists",
        "value": null,
        "confidence_contribution": "confirmed"
      },
      {
        "field_path": "questionnaire_data.step_3.antibiotics_frequency",
        "operator": "in",
        "value": ["once", "twice", "three_plus", "one", "two", "three"],
        "confidence_contribution": "confirmed"
      }
    ],
    "logic": "or",
    "default_confidence": "likely",
    "questionnaire_display_text": "Recent antibiotic use reported"
  },

